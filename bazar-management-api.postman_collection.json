    {
      "name": "Clientes",
      "item": [
        {
          "name": "Listar clientes (solo activos)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/clientes", "host": ["{{baseUrl}}"], "path": ["clientes"] }
          }
        },
        {
          "name": "Listar clientes (incluyendo inactivos)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/clientes?incluirInactivos=true", "host": ["{{baseUrl}}"], "path": ["clientes"], "query": [ { "key": "incluirInactivos", "value": "true" } ] }
          }
        },
        {
          "name": "Obtener cliente por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/clientes/{{clienteId}}", "host": ["{{baseUrl}}"], "path": ["clientes", "{{clienteId}}"] }
          }
        },
        {
          "name": "Crear cliente (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('clienteId', pm.response.json().id);",
                  "  console.log('clienteId =', pm.collectionVariables.get('clienteId'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
