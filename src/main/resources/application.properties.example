spring.application.name=bazar

# ===================================================================
# CONFIGURACIÓN DE LA BASE DE DATOS (MySQL)
# ===================================================================
# Copiá este archivo como 'application.properties' y completá tus credenciales.
spring.datasource.url=jdbc:mysql://localhost:3306/bazar_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=TU_USUARIO
spring.datasource.password=TU_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ===================================================================
# CONFIGURACIÓN DE JPA / HIBERNATE
# ===================================================================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# Muestra las sentencias SQL que genera Hibernate en la consola (útil para el CRUD)
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

server.port=8081
